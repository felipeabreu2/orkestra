{
  "name": "orkestra",
  "version": "1.0.0",
  "description": "Canvas de orquestração de agentes de código de IA",
  "keywords": [
    "electron",
    "ai-agents",
    "orchestration",
    "canvas",
    "terminal"
  ],
  "homepage": "https://github.com/felipeabreu2/orkestra#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/felipeabreu2/orkestra.git"
  },
  "author": "Felipe Abreu <98717420+felipeabreu2@users.noreply.github.com>",
  "license": "MIT",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "rebuild": "electron-rebuild -f -w node-pty",
    "package": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.11.2",
    "electron-updater": "^6.8.9",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.14"
  }
}
